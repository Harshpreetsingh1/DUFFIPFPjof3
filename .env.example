# GitHub Secrets Required

# ----------------------

# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# S3 Buckets
STAGING_S3_BUCKET=app-staging-bucket
PRODUCTION_S3_BUCKET=app-production-bucket
PREVIEW_S3_BUCKET=app-preview-bucket

# CloudFront Distribution IDs
STAGING_CLOUDFRONT_ID=EXXXXXXXXXXXXX
PRODUCTION_CLOUDFRONT_ID=EXXXXXXXXXXXXX

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T...

# Optional
CODECOV_TOKEN=your_codecov_token
